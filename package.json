{
  "name": "cook-county-analysis",
  "version": "1.0.0",
  "description": "Cook County Uniformity & Sales Analysis Tool",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"cd client && npm start\"",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
